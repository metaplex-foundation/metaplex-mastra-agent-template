# =============================================================================
# Test UI -- local environment (packages/ui/.env.local)
#
# Copy to .env.local and fill in the values. .env.local is gitignored by Next.js
# (see packages/ui/.gitignore); never commit real secrets.
# =============================================================================

# WebSocket host the UI connects to. For local dev this is "localhost".
# In production, set it to the hostname the WebSocket server is reachable at.
NEXT_PUBLIC_WS_HOST=localhost

# WebSocket port. Must match WEB_CHANNEL_PORT in the server's .env
# (default 3002).
NEXT_PUBLIC_WS_PORT=3002

# Shared secret -- MUST match WEB_CHANNEL_TOKEN in the server's .env.
# Must be at least 32 characters (same rule as the server-side env var).
# Do not commit a real value.
NEXT_PUBLIC_WS_TOKEN=

# Solana RPC endpoint used by the browser wallet adapter. Can be the same as
# SOLANA_RPC_URL in the server's .env, or a separate client-facing endpoint.
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Solana cluster used to build Solana Explorer links for transactions shown in
# the UI. One of: mainnet-beta | devnet | testnet.
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
