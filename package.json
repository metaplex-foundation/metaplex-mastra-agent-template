{
  "name": "metaplex-agent-template",
  "version": "0.1.0",
  "private": true,
  "description": "Template for building Metaplex Agent Registry agents",
  "scripts": {
    "setup": "tsx scripts/setup.ts",
    "doctor": "pnpm --filter @metaplex-foundation/core... build && tsx scripts/doctor.ts",
    "dev": "pnpm --filter @metaplex-foundation/core... build && pnpm --filter @metaplex-foundation/server dev",
    "dev:full": "pnpm --filter @metaplex-foundation/core... build && tsx scripts/dev-full.ts",
    "dev:ui": "pnpm --dir ../metaplex-agent-chat-template dev",
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "typecheck": "pnpm --filter @metaplex-foundation/core... build && pnpm -r typecheck",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "test": "pnpm --filter @metaplex-foundation/core... build && pnpm -r test",
    "test:coverage": "pnpm --filter @metaplex-foundation/core... build && pnpm -r test:coverage",
    "test:unit": "pnpm -r test:unit",
    "test:integration": "pnpm --filter @metaplex-foundation/core... build && pnpm -r test:integration",
    "test:e2e": "pnpm --filter @metaplex-foundation/server build && pnpm --filter @metaplex-foundation/server test:e2e"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.4",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
