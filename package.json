{
  "name": "metaplex-agent-template",
  "version": "0.1.0",
  "private": true,
  "description": "Template for building Metaplex Agent Registry agents",
  "scripts": {
    "dev": "pnpm --filter @metaplex-agent/shared --filter @metaplex-agent/core build && pnpm --filter @metaplex-agent/server dev",
    "dev:ui": "pnpm --filter @metaplex-agent/ui dev",
    "dev:all": "pnpm --filter @metaplex-agent/shared --filter @metaplex-agent/core build && pnpm --filter @metaplex-agent/server --filter @metaplex-agent/ui dev",
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "typecheck": "pnpm --filter @metaplex-agent/shared --filter @metaplex-agent/core build && pnpm -r typecheck",
    "bootstrap": "tsx scripts/bootstrap.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
