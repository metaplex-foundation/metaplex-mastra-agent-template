# =============================================================================
# Metaplex Agent Template -- minimal happy-path .env
#
# Copy to .env (`cp .env.example .env`) and fill the four REQUIRED values.
# Everything else has a sensible default. For the full catalog of tunables
# (rate limits, RPC budgets, autonomous-mode worker knobs, etc.) see
# `.env.advanced.example` and `docs/SPEC.md` §8.1.
#
# Quick start:
#   pnpm setup       # interactive: generates AGENT_KEYPAIR, prompts for the rest
#   pnpm doctor      # validates this file + RPC reachability + LLM key
#   pnpm dev:full    # runs server and chat UI together
# =============================================================================

# "public" (users sign their own txs) or "autonomous" (agent signs everything).
AGENT_MODE=public

# Agent keypair. Required in both modes. Either a base58 secret key (64 bytes)
# OR a JSON byte array like [1,2,3,...64 entries]. Generate with `pnpm setup`,
# `solana-keygen new --outfile /dev/stdout`, or any wallet's "export private key".
AGENT_KEYPAIR=

# LLM. One key required. Default model is Anthropic Claude; switch by editing
# LLM_MODEL in .env.advanced.example.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=

# Solana RPC. The default works for development; use a paid provider in prod.
SOLANA_RPC_URL=https://api.devnet.solana.com

# OPTIONAL — wallet allowlist. Comma-separated base58 pubkeys. When set in
# public mode, only listed wallets (plus the on-chain owner) can authenticate.
# Leave empty for an "open" agent that any wallet can sign in to.
WALLET_ALLOWLIST=

# OPTIONAL — autonomous mode pre-registration only. The wallet that will
# trigger the first register-agent call. After registration the on-chain
# owner takes precedence and this is no longer consulted.
# BOOTSTRAP_WALLET=
